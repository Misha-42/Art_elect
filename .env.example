# Art_elect — переменные окружения (пример)
# Копировать в .env и заполнить

# SCADA connection
SCADA_HOST=localhost
SCADA_PORT=502
SCADA_PROTOCOL=modbus

# Базы данных
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=art_elect
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme

TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=telemetry

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=art_elect/telemetry

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Безопасность
SECRET_KEY=changeme
TLS_CERT_PATH=
TLS_KEY_PATH=
LDAP_SERVER=ldap://localhost:389

# Данные
DATA_DIR=./data
MODELS_DIR=./models
